# Copy to .env and fill in. Both apps run without any of these
# (FakeLLM + mock data), so you can explore before signing up for anything.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Any model on openrouter.ai/models — e.g. openai/gpt-4o-mini, anthropic/claude-3.5-haiku
LLM_MODEL=openai/gpt-4o-mini
LOG_LEVEL=INFO
ENVIRONMENT=local

# Job sources. Missing key = that source is skipped; the app still runs.
# JSearch (RapidAPI) aggregates LinkedIn/Indeed/Glassdoor legitimately.
JSEARCH_API_KEY=

# Force offline mode
USE_FAKE_LLM=false
USE_MOCK_SOURCES=false
