# Copy to .env and fill in. App runs without any of these (FakeLLM + mock data).

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LOG_LEVEL=INFO
ENVIRONMENT=local

# Job sources
JSEARCH_API_KEY=

# Apollo.io — recruiter/hiring manager lookup (app.apollo.io)
APOLLO_API_KEY=

# SMTP — daily digest email (Gmail: use an App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFICATION_EMAIL=

# Daily scheduler
DAILY_SEARCH_QUERY=
DAILY_RUN_HOUR=8
BASE_URL=http://localhost:8000

# Force offline mode
USE_FAKE_LLM=false
USE_MOCK_SOURCES=false
